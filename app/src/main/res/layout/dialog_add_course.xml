<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_add_course_panel"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="课程信息"
                android:textColor="#6A4321"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="课程名称"
                android:textColor="#7A5732"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/inputCourseName"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_add_course_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="#4A321C"
                android:textColorHint="#8C7A64" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="授课教师（可留空）"
                android:textColor="#7A5732"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/inputTeacher"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_add_course_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="#4A321C"
                android:textColorHint="#8C7A64" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="上课地点（可留空）"
                android:textColor="#7A5732"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/inputLocation"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_add_course_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="#4A321C"
                android:textColorHint="#8C7A64" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="时间信息"
                android:textColor="#6A4321"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="星期"
                android:textColor="#7A5732"
                android:textSize="12sp" />

            <Spinner
                android:id="@+id/inputWeekday"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_add_course_input" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="开始节"
                    android:textColor="#7A5732"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="结束节"
                    android:textColor="#7A5732"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/inputStartSection"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_add_course_input"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="#4A321C"
                    android:textColorHint="#8C7A64" />

                <EditText
                    android:id="@+id/inputEndSection"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_add_course_input"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="#4A321C"
                    android:textColorHint="#8C7A64" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="开始周"
                    android:textColor="#7A5732"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="结束周"
                    android:textColor="#7A5732"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/inputStartWeek"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_add_course_input"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="#4A321C"
                    android:textColorHint="#8C7A64" />

                <EditText
                    android:id="@+id/inputEndWeek"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_add_course_input"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="#4A321C"
                    android:textColorHint="#8C7A64" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="单双周规则"
                android:textColor="#7A5732"
                android:textSize="12sp" />

            <RadioGroup
                android:id="@+id/inputParityGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/parityAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="单双周都上"
                    android:textColor="#5A3D1F" />

                <RadioButton
                    android:id="@+id/parityOdd"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="仅单周"
                    android:textColor="#5A3D1F" />

                <RadioButton
                    android:id="@+id/parityEven"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="仅双周"
                    android:textColor="#5A3D1F" />
            </RadioGroup>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="end"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/cancelManualAddButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="#33FFFFFF"
                    android:text="取消"
                    android:textAllCaps="false"
                    android:textColor="#5A3D1F" />

                <Button
                    android:id="@+id/saveManualAddButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="#EFD7B1"
                    android:text="保存"
                    android:textAllCaps="false"
                    android:textColor="#4A321C" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>

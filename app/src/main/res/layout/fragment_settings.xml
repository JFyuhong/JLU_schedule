<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="#5A3D1F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_timetable_manage"
            android:textColor="#7A5A37"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/manageTimetableButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_open_timetable_manage"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_default_page"
            android:textColor="#7A5A37"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/defaultOpenGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/defaultOpenTimetable"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/nav_timetable"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/defaultOpenToday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/nav_today"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_semester_start"
            android:textColor="#7A5A37"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/semesterStartDateText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />

            <Button
                android:id="@+id/changeSemesterStartButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_change"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_theme"
            android:textColor="#7A5A37"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/themeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/themeWarm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_theme_warm"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/themeOcean"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_theme_ocean"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/themeMint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_theme_mint"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_font_scale"
            android:textColor="#7A5A37"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/fontScaleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/fontSmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_font_small"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/fontNormal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_font_normal"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/fontLarge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_font_large"
                android:textColor="#5A3D1F"
                android:textSize="14sp" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_non_current"
            android:textColor="#7A5A37"
            android:textSize="15sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/showNonCurrentSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_show_non_current"
            android:textColor="#5A3D1F"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_custom_background"
            android:textColor="#7A5A37"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/chooseBackgroundButton"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_choose_crop"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/clearBackgroundButton"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/settings_restore_default"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_background_hint"
            android:textColor="#7A5A37"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>
